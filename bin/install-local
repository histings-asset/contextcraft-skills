#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "$script_dir/.." && pwd)"
target="${1:-all}"

install_codex() {
  local dest="${CODEX_HOME:-$HOME/.codex}/skills"
  mkdir -p "$dest"
  for skill in "$repo"/skills/*; do
    [[ -d "$skill" && -f "$skill/SKILL.md" ]] || continue
    cp -R "$skill" "$dest/"
  done
  echo "Installed Codex skills to $dest"
}

install_claude() {
  local dest="${CLAUDE_HOME:-$HOME/.claude}/skills"
  mkdir -p "$dest"
  for skill in "$repo"/skills/*; do
    [[ -d "$skill" && -f "$skill/SKILL.md" ]] || continue
    cp -R "$skill" "$dest/"
  done
  echo "Installed Claude skills to $dest"
}

case "$target" in
  codex)
    install_codex
    ;;
  claude)
    install_claude
    ;;
  all)
    install_codex
    install_claude
    ;;
  *)
    echo "Usage: $0 [codex|claude|all]" >&2
    exit 2
    ;;
esac
